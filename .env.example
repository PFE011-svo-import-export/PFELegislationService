# Anthropic (génération de la réponse finale, Claude Sonnet 4.6)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI (vectorisation dense des chunks et des requêtes)
OPENAI_API_KEY=
OPENAI_API_MODEL=text-embedding-3-large

# Cohere (reranking des candidats, rerank-v4.0-fast)
COHERE_API_KEY=

# Qdrant (base de données vectorielle)
# En local (docker compose)  : QDRANT_HOST=localhost, QDRANT_PORT=6333, QDRANT_USE_HTTPS=false
# Sur Qdrant Cloud           : QDRANT_HOST=<id-du-cluster>.<region>.aws.cloud.qdrant.io,
#                              QDRANT_USE_HTTPS=true et QDRANT_API_KEY obligatoire
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_USE_HTTPS=false

# Dossier contenant les documents Markdown à ingérer
DOCUMENTS_PATH=app/documents
