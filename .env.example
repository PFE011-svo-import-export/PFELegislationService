ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama (use http://host.docker.internal:11434 when running via docker compose to reach the host's Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:4b

# Qdrant (use http://qdrant:6333 when running via docker compose)
QDRANT_URL=http://localhost:6333

# Folder scanned by the ingestion pipeline (override when documents are stored externally)
DOCUMENTS_PATH=app/documents